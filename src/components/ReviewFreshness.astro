---
import { formatDate, reviewAge } from '../lib/format';

interface Props {
  date: Date;
  variant?: 'card' | 'detail';
}

const { date, variant = 'card' } = Astro.props;
const review = reviewAge(date);
const due = review.state === 'due';
const text = variant === 'detail'
  ? due
    ? `Review due · last reviewed ${formatDate(date)}`
    : `${review.label} · ${formatDate(date)}`
  : due ? 'Review due' : review.label;
---

{
  variant === 'detail' ? (
    <p class:list={['freshness', 'detail', { due }]}>{text}</p>
  ) : (
    <span class:list={['freshness', 'card', { due }]}>{text}</span>
  )
}

<style>
  .freshness {
    color: var(--muted);
    font-size: 0.9rem;
  }

  /* Inline in the card's bottom meta line — inherits its faint, small styling. */
  .card {
    color: var(--faint);
    font-size: inherit;
  }

  .due {
    color: var(--warn);
    font-weight: 650;
  }
</style>
