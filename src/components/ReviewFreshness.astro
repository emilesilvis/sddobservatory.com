---
import { formatDate, reviewAge } from '../lib/format';

interface Props {
  date: Date;
  variant?: 'card' | 'detail';
}

const { date, variant = 'card' } = Astro.props;
const review = reviewAge(date);
const text = variant === 'detail'
  ? review.stale
    ? `Review due · last reviewed ${formatDate(date)}`
    : `${review.label} · ${formatDate(date)}`
  : review.stale ? 'Review due' : review.label;
---

<p class:list={['freshness', variant, { stale: review.stale }]}>{text}</p>

<style>
  .freshness {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .card {
    margin: 0 0 0.75rem;
    font-size: 0.82rem;
  }

  .stale {
    color: var(--warn);
    font-weight: 650;
  }
</style>
