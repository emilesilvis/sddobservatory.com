---
import type { CollectionEntry } from 'astro:content';
import type { RepoMetrics } from '../lib/metrics-schema';
import { driftTone, statusTone } from '../lib/labels';
import { formatCount, relativeDate } from '../lib/format';
import Badge from './Badge.astro';
import GitHubIcon from './GitHubIcon.astro';
import RichText from './RichText.astro';
import ReviewFreshness from './ReviewFreshness.astro';

interface Props {
  project: CollectionEntry<'projects'>;
  frameworkName: string;
  metrics: RepoMetrics | undefined;
}

const { project, frameworkName, metrics } = Astro.props;
const { data } = project;
---

<article class="card">
  <header>
    <h3><a class="card-link" href={`/projects/${project.id}/`}>{data.name}</a></h3>
    <span class="badges">
      {data.status !== 'active' && <Badge label={data.status} tone={statusTone(data.status)} />}
      <Badge label={`drift: ${data.drift}`} tone={driftTone(data.drift)} title="Spec-to-code drift" />
    </span>
  </header>
  <p class="summary"><RichText text={data.summary} /></p>
  <ReviewFreshness date={data.lastReviewed} />
  <p class="meta">
    <a class="repo" href={`https://github.com/${data.repo}`} title="View on GitHub">
      <GitHubIcon />
      {data.repo}
    </a>
    {' '}· <span class="nowrap">using {frameworkName}</span>
    {metrics && (
      <>
        {' '}· <span class="nowrap">★ {formatCount(metrics.stars)} stars</span> ·{' '}
        <span class="nowrap">pushed {relativeDate(metrics.pushedAt)}</span>
      </>
    )}
  </p>
  <span class="view" aria-hidden="true">View project →</span>
</article>

<style>
  header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  h3 {
    margin: 0;
    font-size: 1.05rem;
  }

  .badges {
    display: inline-flex;
    gap: 0.35rem;
  }

  .summary {
    color: var(--muted);
    font-size: 0.92rem;
    margin: 0.4rem 0 0.8rem;
  }

  /* In a stretched grid card, park the repo line at the bottom. */
  .meta {
    margin: auto 0 0;
    font-size: 0.82rem;
    color: var(--faint);
    font-variant-numeric: tabular-nums;
  }

  .view {
    margin-top: 0.7rem;
    color: var(--accent);
    font-size: 0.85rem;
    font-weight: 650;
  }
</style>
