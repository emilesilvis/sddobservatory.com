---
import type { CollectionEntry } from 'astro:content';
import type { RepoMetrics } from '../lib/metrics-schema';
import { maturityTone } from '../lib/labels';
import { formatCount, relativeDate } from '../lib/format';
import Badge from './Badge.astro';
import GitHubIcon from './GitHubIcon.astro';
import RichText from './RichText.astro';

interface Props {
  framework: CollectionEntry<'frameworks'>;
  metrics: RepoMetrics | undefined;
}

const { framework, metrics } = Astro.props;
const { data } = framework;
const tools = data.supportedTools.slice(0, 4);
const moreTools = data.supportedTools.length - tools.length;
---

<article class="card">
  <header>
    <h3><a class="card-link" href={`/frameworks/${framework.id}/`}>{data.name}</a></h3>
    <Badge label={data.maturity} tone={maturityTone(data.maturity)} />
  </header>
  <p class="summary"><RichText text={data.summary} /></p>
  <ul class="chip-list">
    {tools.map((tool) => <li class="chip">{tool}</li>)}
    {moreTools > 0 && <li class="chip">+{moreTools} more</li>}
  </ul>
  {
    data.repo && (
      <p class="meta">
        <a class="repo" href={`https://github.com/${data.repo}`} title="View on GitHub">
          <GitHubIcon />
          {data.repo}
        </a>
        {metrics && (
          <>
            {' '}· <span class="nowrap">★ {formatCount(metrics.stars)} stars</span> ·{' '}
            <span class="nowrap">pushed {relativeDate(metrics.pushedAt)}</span>
          </>
        )}
      </p>
    )
  }
</article>

<style>
  header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
  }

  h3 {
    margin: 0;
    font-size: 1.05rem;
  }

  .summary {
    color: var(--muted);
    font-size: 0.92rem;
    margin: 0.4rem 0 0.8rem;
  }

  /* In a stretched grid card, park the chips + repo line at the bottom. */
  .chip-list {
    margin-top: auto;
  }

  .meta {
    margin: 0.8rem 0 0;
    font-size: 0.82rem;
    color: var(--faint);
    font-variant-numeric: tabular-nums;
  }
</style>
