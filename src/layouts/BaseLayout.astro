---
import '../styles/global.css';
import { SITE } from '../lib/site';

interface Props {
  title?: string;
  description?: string;
}

const { title, description = SITE.description } = Astro.props;
// Content strings may carry `backtick` code spans; meta tags want plain text.
const plainDescription = description.replaceAll('`', '');
const fullTitle = title ? `${title} · ${SITE.name}` : `${SITE.name} — ${SITE.tagline}`;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site) : undefined;

const nav = [
  { href: '/frameworks/', label: 'Frameworks' },
  { href: '/projects/', label: 'Projects' },
  { href: '/methodology/', label: 'Methodology' },
  { href: '/submit/', label: 'Submit' },
];
const currentPath = Astro.url.pathname;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={plainDescription} />
    {canonical && <link rel="canonical" href={canonical} />}
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={plainDescription} />
    <meta property="og:type" content="website" />
    {canonical && <meta property="og:url" content={canonical} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body>
    <header>
      <div class="container bar">
        <a class="brand" href="/">SDD <span>Observatory</span></a>
        <nav>
          {
            nav.map((item) => (
              <a href={item.href} aria-current={currentPath.startsWith(item.href) ? 'page' : undefined}>
                {item.label}
              </a>
            ))
          }
          <a class="github-link" href={SITE.repoUrl} target="_blank" rel="noopener" aria-label="View source on GitHub">
            <svg viewBox="0 0 16 16" width="20" height="20" fill="currentColor" aria-hidden="true">
              <path
                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"
              />
            </svg>
          </a>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer>
      <div class="container">
        <p>{SITE.name} — {SITE.tagline}</p>
        <p>
          Community-maintained. Data and site source on
          <a href={SITE.repoUrl}>GitHub</a> · <a href="/methodology/">Methodology</a> ·
          <a href="/submit/">Submit a framework or project</a>
        </p>
        <p>
          Content licensed under
          <a href="https://creativecommons.org/licenses/by-sa/4.0/">CC BY-SA 4.0</a> · site code under
          <a href={`${SITE.repoUrl}/blob/main/LICENSE`}>MIT</a>
        </p>
      </div>
    </footer>
  </body>
</html>

<style>
  header {
    border-bottom: 1px solid var(--line);
    background: var(--surface);
  }

  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding-top: 0.9rem;
    padding-bottom: 0.9rem;
  }

  .brand {
    font-weight: 750;
    font-size: 1.1rem;
    color: var(--ink);
    letter-spacing: -0.01em;
  }

  .brand span {
    color: var(--accent);
  }

  .brand:hover {
    text-decoration: none;
  }

  nav {
    display: flex;
    gap: 1.2rem;
    flex-wrap: wrap;
  }

  nav a {
    color: var(--muted);
    font-weight: 550;
    font-size: 0.95rem;
  }

  nav a:hover {
    color: var(--ink);
    text-decoration: none;
  }

  nav a[aria-current='page'] {
    color: var(--accent);
  }

  .github-link {
    display: inline-flex;
    align-items: center;
    padding-left: 1.2rem;
    border-left: 1px solid var(--line);
  }

  .github-link svg {
    display: block;
  }

  main {
    min-height: 60vh;
    padding-bottom: 4rem;
  }

  footer {
    border-top: 1px solid var(--line);
    padding: 2rem 0 3rem;
    color: var(--muted);
    font-size: 0.9rem;
    background: var(--surface);
  }

  footer p {
    margin: 0 0 0.4rem;
  }
</style>
