---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FrameworkCard from '../../components/FrameworkCard.astro';
import DirectoryControls from '../../components/DirectoryControls.astro';
import { getMetrics } from '../../lib/metrics';
import { MATURITY_LEVELS } from '../../content.config';

const frameworks = (await getCollection('frameworks')).sort(
  (a, b) =>
    (getMetrics(b.data.repo)?.stars ?? 0) - (getMetrics(a.data.repo)?.stars ?? 0) ||
    a.data.name.localeCompare(b.data.name),
);
const tools = [...new Set(frameworks.flatMap((framework) => framework.data.supportedTools))].sort();
---

<BaseLayout
  title="Frameworks"
  description="A directory of spec-driven development frameworks: their approach, workflow, supported tools, maturity, and real-world usage."
>
  <header class="page-header">
    <h1>Frameworks</h1>
    <p>
      Spec-driven development frameworks we track: how each one works, which tools it supports, how mature it is, and
      which real projects use it. <a href="/compare/">Compare them side by side</a>, or, if one is missing,
      <a href="/submit/">submit it</a>.
    </p>
  </header>

  <DirectoryControls
    itemLabel="frameworks"
    filters={[
      { key: 'maturity', label: 'Maturity', options: MATURITY_LEVELS.map((value) => ({ value, label: value })) },
      { key: 'supportedTools', label: 'Supported tool', options: tools.map((value) => ({ value, label: value })) },
    ]}
    sorts={[
      { value: 'stars', label: 'GitHub stars' },
      { value: 'reviewed', label: 'Recently reviewed' },
      { value: 'name', label: 'Name' },
    ]}
    defaultSort="stars"
  />

  <ul class="card-grid" data-directory-grid data-singular="framework" data-plural="frameworks">
    {
      frameworks.map((framework) => (
        <li
          data-name={framework.data.name.toLocaleLowerCase()}
          data-search={`${framework.data.name} ${framework.data.summary} ${framework.data.supportedTools.join(' ')}`}
          data-maturity={framework.data.maturity}
          data-supported-tools={framework.data.supportedTools.join('|')}
          data-stars={getMetrics(framework.data.repo)?.stars ?? 0}
          data-reviewed={framework.data.lastReviewed.getTime()}
        >
          <FrameworkCard framework={framework} metrics={getMetrics(framework.data.repo)} />
        </li>
      ))
    }
  </ul>
</BaseLayout>
