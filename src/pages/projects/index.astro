---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import DirectoryControls from '../../components/DirectoryControls.astro';
import { getMetrics } from '../../lib/metrics';
import { reviewAge } from '../../lib/format';

const frameworks = await getCollection('frameworks');
const frameworkNames = new Map(frameworks.map((f) => [f.id, f.data.name]));

const projects = (await getCollection('projects')).sort((a, b) => {
  const aPush = getMetrics(a.data.repo)?.pushedAt;
  const bPush = getMetrics(b.data.repo)?.pushedAt;
  return (bPush ? new Date(bPush).getTime() : 0) - (aPush ? new Date(aPush).getTime() : 0);
});
---

<BaseLayout
  title="Projects"
  description="Real-world projects tracked over time: which SDD framework they use, how their specs are structured, and how specs and code evolve together."
>
  <header class="page-header">
    <h1>Tracked projects</h1>
    <p>
      Real repositories using spec-driven development, tracked over time: spec structure, activity, spec-to-code
      drift, and maintenance outcomes. Know a project we should track? <a href="/submit/">Submit it</a>.
    </p>
  </header>

  <DirectoryControls
    itemLabel="projects"
    filters={[
      { key: 'framework', label: 'Framework', options: frameworks.sort((a, b) => a.data.name.localeCompare(b.data.name)).map((framework) => ({ value: framework.id, label: framework.data.name })) },
      { key: 'status', label: 'Status', options: ['active', 'paused', 'archived'].map((value) => ({ value, label: value })) },
      { key: 'drift', label: 'Drift', options: ['none', 'low', 'moderate', 'high', 'unknown'].map((value) => ({ value, label: value })) },
      { key: 'review', label: 'Review state', options: [{ value: 'due', label: 'Review due' }, { value: 'current', label: 'Current' }] },
    ]}
    sorts={[
      { value: 'activity', label: 'Recently active' },
      { value: 'reviewed', label: 'Recently reviewed' },
      { value: 'name', label: 'Name' },
    ]}
    defaultSort="activity"
  />

  <ul class="card-grid" data-directory-grid data-singular="project" data-plural="projects" data-default-sort="activity">
    {
      projects.map((project) => (
        <li
          data-name={project.data.name.toLocaleLowerCase()}
          data-search={`${project.data.name} ${project.data.summary} ${project.data.repo}`}
          data-framework={project.data.framework.id}
          data-status={project.data.status}
          data-drift={project.data.drift}
          data-review={reviewAge(project.data.lastReviewed).state}
          data-activity={getMetrics(project.data.repo)?.pushedAt ? new Date(getMetrics(project.data.repo)!.pushedAt).getTime() : 0}
          data-reviewed={project.data.lastReviewed.getTime()}
        >
          <ProjectCard
            project={project}
            frameworkName={frameworkNames.get(project.data.framework.id) ?? project.data.framework.id}
            metrics={getMetrics(project.data.repo)}
          />
        </li>
      ))
    }
  </ul>
</BaseLayout>
